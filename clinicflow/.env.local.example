# =====================================================
# HOW TO ENABLE GOOGLE SIGN-IN
# =====================================================
# 1. Go to Supabase Dashboard → Authentication → Providers → Google
# 2. Enable Google and add your Client ID + Secret from Google Cloud Console
# 3. Set the Redirect URI in Google Cloud Console to:
#    https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
# 4. Set NEXT_PUBLIC_APP_URL below to your app's URL (for OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

